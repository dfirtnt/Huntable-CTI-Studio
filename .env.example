# CTI Studio environment configuration
# Copy to .env and fill in the two required values.
# Everything else is configured in the Settings UI after first run.

# Required: PostgreSQL database password
POSTGRES_PASSWORD=your_secure_postgres_password_change_this

# LLM API keys (set whichever providers you use)
# These seed the Settings UI on first run; after that the UI manages them.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
