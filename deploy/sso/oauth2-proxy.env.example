# oauth2-proxy configuration for Huntable CTI Studio enterprise SSO.
# setup.sh copies this to deploy/sso/oauth2-proxy.env (gitignored) with the provider
# and redirect URL prefilled. Fill in the client credentials below, then start the overlay.
#
# Generate the cookie secret (32 random bytes, url-safe base64):
#   python3 -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"

OAUTH2_PROXY_PROVIDER=__SSO_PROVIDER__
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_COOKIE_SECURE=true
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_REDIRECT_URL=https://__SSO_HOSTNAME__/oauth2/callback

# --- GitHub (OAUTH2_PROXY_PROVIDER=github) ---------------------------------------
# Create an OAuth App at https://github.com/settings/developers
#   Authorization callback URL = https://__SSO_HOSTNAME__/oauth2/callback
# Restrict access and surface team slugs as groups (-> X-Auth-Request-Groups, e.g. "org:team"):
# OAUTH2_PROXY_GITHUB_ORG=your-org
# OAUTH2_PROXY_GITHUB_TEAM=cti-admins,cti-operators,cti-reviewers,cti-analysts

# --- Google (OAUTH2_PROXY_PROVIDER=google) ---------------------------------------
# OAUTH2_PROXY_OIDC_ISSUER_URL=https://accounts.google.com
# Google Workspace groups require a service account; see oauth2-proxy docs.
# OAUTH2_PROXY_GOOGLE_GROUP=cti-admins@your-domain.com

# --- Microsoft Entra ID / generic OIDC (OAUTH2_PROXY_PROVIDER=oidc) --------------
# OAUTH2_PROXY_OIDC_ISSUER_URL=https://login.microsoftonline.com/<tenant-id>/v2.0
# OAUTH2_PROXY_SCOPE=openid email profile groups
# OAUTH2_PROXY_ALLOWED_GROUPS=<group-object-id>
