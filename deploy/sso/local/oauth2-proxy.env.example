# Entra ID (Microsoft) OIDC config for the local login gate.
# Copy to oauth2-proxy.env and fill in the four values below.
#
# From your Entra app registration (Azure portal -> Microsoft Entra ID -> App registrations):
#   - Directory (tenant) ID   -> __TENANT_ID__ in the issuer URL below
#   - Application (client) ID -> OAUTH2_PROXY_CLIENT_ID
#   - A client secret VALUE   -> OAUTH2_PROXY_CLIENT_SECRET  (Certificates & secrets -> New client secret)
# Redirect URI registered in Entra (platform: Web):  http://localhost:4180/oauth2/callback
#
# Cookie secret (run once):
#   python3 -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"

OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_OIDC_ISSUER_URL=https://login.microsoftonline.com/__TENANT_ID__/v2.0
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_REDIRECT_URL=http://localhost:4180/oauth2/callback
OAUTH2_PROXY_SCOPE=openid email profile

# --- Entra gotchas (uncomment if login succeeds but oauth2-proxy rejects the user) ---
# Entra v2 tokens may omit a verified "email"; fall back to the UPN:
# OAUTH2_PROXY_OIDC_EMAIL_CLAIM=preferred_username
# Accept emails Entra does not flag as verified:
# OAUTH2_PROXY_INSECURE_OIDC_ALLOW_UNVERIFIED_EMAIL=true
